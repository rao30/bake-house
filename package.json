{
  "name": "bake-house-menu",
  "version": "1.0.0",
  "description": "Single page BakeHouse menu for Railway deployment",
  "main": "server.js",
  "scripts": {
    "build:festivals": "node scripts/generate-festival-pages.js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "build": "npm run build:festivals && npm run build:css",
    "prestart": "npm run build",
    "start": "node server.js",
    "thumbnails": "node scripts/generate-thumbnails.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  }
}
